---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import ProjectCard from "@components/ProjectCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";
import Bio from "../content/bio.md";

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_POSTS_ON_HOMEPAGE);

const allProjectEntries = await getCollection("projects");
const highlights = allProjectEntries
  .filter(p => p.slug.endsWith("/highlights") && !p.data.draft)
  .sort((a, b) => (a.data.order ?? Infinity) - (b.data.order ?? Infinity))
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);
const detailFolders = new Set(
  allProjectEntries
    .filter(p => p.slug.endsWith("/long_description"))
    .map(p => p.slug.split("/")[0])
);

const allwork = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf())
  .slice(0,SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);

---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-16">
      <section class="flex gap-8 items-center">
        <article class="animate space-y-4 prose-sm flex-1">
          <Bio />
        </article>
        <div class="animate flex flex-col gap-3 shrink-0 items-center w-36">
          <img
            src="/Yosemite_Self.jpeg"
            alt="Alex Hwang"
            class="rounded-xl w-full object-cover"
          />
          <ul class="flex flex-col gap-1 text-center text-sm font-serif">
            {SOCIALS.map(SOCIAL => (
              <li class="text-nowrap">
                <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                  {SOCIAL.NAME}
                </Link>
              </li>
            ))}
            <li>
              <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>
                {SITE.EMAIL}
              </Link>
            </li>
          </ul>
        </div>
      </section>

      <section class="animate space-y-6 prose-sm">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Project highlights
          </h5>          
        </div>
        <ul class="flex flex-col gap-4">
          {highlights.map(project => {
            const folder = project.slug.split("/")[0];
            const detailHref = detailFolders.has(folder) ? `/projects/${folder}` : undefined;
            return (
              <li>
                <ProjectCard entry={project} detailHref={detailHref} />
              </li>
            );
          })}
        </ul>
      </section>

      <section class="animate space-y-6 prose-sm">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Latest posts
          </h5>
          <Link href="/blog">
            See all posts
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
      </section>

     
    </div>
  </Container>
</PageLayout>
