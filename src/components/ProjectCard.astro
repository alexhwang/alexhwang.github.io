---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"projects">;
  detailHref?: string;
}

const { entry, detailHref } = Astro.props;
const Tag = detailHref ? "a" : "div";
const { Content } = await entry.render();
---

<Tag href={detailHref} class={`flex flex-col gap-2 transition-colors duration-300 ease-in-out${detailHref ? " group hover:text-black dark:hover:text-white" : ""}`}>
  <div class="font-serif font-semibold text-black dark:text-white text-sm">{entry.data.title}</div>
  {entry.data.image && (
    <img src={entry.data.image} alt={entry.data.title} class="rounded-md object-cover" style={`width: ${entry.data.imageWidth ?? "100%"}`} />
  )}
  <article class="prose-sm">
    <Content />
  </article>
</Tag>
